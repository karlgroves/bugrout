{
  "threshold": 1.5,
  "minTokens": 50,
  "minLines": 5,
  "maxLines": 1000,
  "maxSize": "100kb",
  "reporters": ["consoleFull"],
  "output": "./reports/jscpd",
  "format": ["typescript", "tsx", "javascript", "jsx", "markdown"],
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/.expo/**",
    "**/*.test.{ts,tsx,js,jsx}",
    "**/*.spec.{ts,tsx,js,jsx}",
    "**/__tests__/**",
    "**/e2e/**",
    "**/__fixtures__/**",
    "**/__snapshots__/**",
    "**/generated/**",
    "**/*.generated.*",
    "**/*.min.*",
    "**/native-modules/**",
    "data-pipeline/**"
  ],
  "absolute": true,
  "gitignore": true,
  "silent": false
}
