{
  "name": "bugrout",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "eslint . --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "doctor": "pnpm --filter @bugrout/mobile run doctor",
    "bundle:check": "pnpm --filter @bugrout/mobile run bundle:check",
    "clean": "turbo run clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "markdownlint": "markdownlint-cli2 \"**/*.md\"",
    "markdownlint:fix": "markdownlint-cli2 --fix \"**/*.md\"",
    "dupes": "jscpd .",
    "links": "lychee --no-progress --config lychee.toml \"./**/*.md\"",
    "security:audit": "pnpm audit --prod --audit-level=high",
    "security:osv": "osv-scanner scan --lockfile pnpm-lock.yaml",
    "security:semgrep": "semgrep scan --config p/typescript --config p/react --config p/owasp-top-ten --config p/secrets --error --metrics=off --quiet",
    "security:secrets": "gitleaks detect --no-banner --redact",
    "security": "run-p security:audit security:osv security:secrets",
    "license:check": "node scripts/check-licenses.mjs",
    "license:report": "pnpm licenses list --prod --long > reports/licenses.txt || pnpm licenses list --prod",
    "check": "run-s format:check lint typecheck test markdownlint",
    "check:all": "run-s check doctor dupes links security security:semgrep license:check",
    "ci": "pnpm run check:all",
    "ai:context": "node scripts/ai-context.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{js,jsx,mjs,cjs}": [
      "prettier --write"
    ],
    "*.md": [
      "markdownlint-cli2 --fix",
      "prettier --write"
    ],
    "*.{json,jsonc,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@eslint/compat": "2.1.0",
    "@eslint/js": "9.39.5",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-expo": "1.0.3",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jsdoc": "63.0.1",
    "eslint-plugin-n": "18.0.1",
    "eslint-plugin-no-secrets": "2.3.3",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-native-a11y": "3.5.1",
    "eslint-plugin-security": "4.0.0",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-unicorn": "64.0.0",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jscpd": "4.2.4",
    "lint-staged": "17.0.7",
    "markdownlint-cli2": "0.22.1",
    "npm-run-all2": "9.0.1",
    "prettier": "3.8.3",
    "turbo": "^2.9.16",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.60.1"
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ],
    "overrides": {
      "@babel/core@<7.29.6": ">=7.29.6 <8",
      "@tootallnate/once@2.0.0": ">=2.0.1",
      "@xmldom/xmldom@<0.8.13": ">=0.8.13",
      "brace-expansion@5.0.5": ">=5.0.6",
      "fast-uri@<=3.1.1": ">=3.1.2",
      "js-yaml@>=3 <3.15.0": ">=3.15.0 <4",
      "postcss@>=8 <8.5.10": ">=8.5.10",
      "shell-quote@<1.8.4": ">=1.8.4",
      "undici@<6.27.0": ">=6.27.0 <7",
      "uuid@<11.1.1": ">=11.1.1 <12",
      "ws@>=6 <6.2.4": ">=6.2.4 <7",
      "ws@>=7 <7.5.11": ">=7.5.11 <8",
      "ws@>=8 <8.20.1": ">=8.20.1"
    }
  }
}
