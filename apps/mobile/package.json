{
  "name": "@bugrout/mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "doctor": "expo-doctor",
    "bundle:ios": "expo export --platform ios --output-dir .expo-export/ios",
    "bundle:android": "expo export --platform android --output-dir .expo-export/android",
    "bundle:check": "pnpm run bundle:ios && pnpm run bundle:android",
    "e2e:build": "detox build --configuration android.emu.release",
    "e2e:test": "detox test --configuration android.emu.release",
    "e2e:smoke": "detox test --configuration android.emu.release --record-logs all --take-screenshots failing e2e/navigation-flow.test.ts"
  },
  "dependencies": {
    "@bugrout/shared": "workspace:*",
    "@expo/vector-icons": "^15.1.1",
    "@maplibre/maplibre-react-native": "^10.4.2",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.36",
    "expo-battery": "~10.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-network": "~8.0.8",
    "expo-router": "~6.0.23",
    "expo-sms": "~14.0.8",
    "expo-speech": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-get-random-values": "^2.0.0",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.5.1",
    "uuid": "^14.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@config-plugins/detox": "11.0.0",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/jest": "29.5.14",
    "@types/node": "^22.19.17",
    "@types/react": "~19.1.17",
    "@types/uuid": "^10.0.0",
    "detox": "20.51.4",
    "expo-doctor": "1.20.1",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "19.1.0",
    "ts-jest": "29.4.11",
    "typescript": "~5.9.3"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "react-native-get-random-values"
      ]
    }
  }
}
